# User data - local-first, never committed (see SECURITY.md)
data/*
!data/.gitkeep

# demo sandbox (generated by --demo)
data_demo/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/

# Challenge workspace (user's in-progress solutions live outside the repo's tracked files)
workspace/

# dev render artifacts
_preview_*.png

# generated placeholder art pack (run tools/make_placeholder_art.py to recreate)
characters/art/_placeholder/

# a stray clone of this repo nested inside the working copy - never track it
/echoself/
